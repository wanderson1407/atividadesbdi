# Variáveis de Ambiente para Google Cloud Run
# =============================================================================
# Use este arquivo como referência para configurar as variáveis no console do Cloud Run

# Projeto Google Cloud
GOOGLE_CLOUD_PROJECT=atividades-intel

# OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=945799576026-7dp9aeogap6hmrldi4kpedchitnirci5.apps.googleusercontent.com

# JWT Secret Key
# IMPORTANTE: Gere uma nova chave forte antes do deploy!
# Execute: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=SUBSTITUA_PELA_CHAVE_FORTE_GERADA

# Configuração do Firestore
USE_MOCK_FIRESTORE=false

# Autenticação (NUNCA use true em produção!)
DEV_AUTH=false

# Ambiente
ENVIRONMENT=production

# Porta (Cloud Run define automaticamente, mas podemos definir como backup)
PORT=8080

# =============================================================================
# INSTRUÇÕES:
# 1. Gere uma SECRET_KEY forte: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. No Cloud Run console, vá em: Edit & Deploy New Revision > Variables & Secrets
# 3. Adicione cada variável acima (exceto PORT, que é automático)
# 4. Clique em DEPLOY
# =============================================================================
