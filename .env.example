# Exemplo de variáveis de ambiente
# =============================================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com seus valores reais
# Nunca commite o arquivo .env com suas credenciais!

# ======================
# BANCO DE DADOS
# ======================
# USE_MOCK_FIRESTORE: true para usar dados locais (desenvolvimento), false para usar Google Cloud Firestore
USE_MOCK_FIRESTORE=false

# Google Cloud Project ID
# Obtenha em: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=atividades-intel

# Credenciais do Google Cloud (para desenvolvimento local)
# Caminho para o arquivo de credenciais JSON
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=./atividades-intel-5c6eda847742.json

# ======================
# AUTENTICAÇÃO
# ======================
# Google OAuth 2.0 Client ID
# Obtenha em: https://console.cloud.google.com/apis/credentials
# 1. Vá para "Credentials" > "Create Credentials" > "OAuth 2.0 Client IDs"
# 2. Tipo: Web application
# 3. Authorized JavaScript origins: http://localhost:8000, https://seu-dominio.com
# 4. Authorized redirect URIs: http://localhost:8000, https://seu-dominio.com
GOOGLE_CLIENT_ID=945799576026-7dp9aeogap6hmrldi4kpedchitnirci5.apps.googleusercontent.com

# JWT Secret Key - Gere uma chave secreta forte
# Você pode gerar uma com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ======================
# MODO DE DESENVOLVIMENTO
# ======================
# DEV_AUTH: true permite login simulado (apenas para desenvolvimento local!)
# NUNCA deixe como true em produção no Google Cloud!
DEV_AUTH=false

# Email para testes em modo de desenvolvimento (quando DEV_AUTH=true)
DEV_USER_EMAIL=seu-email@gmail.com

# ======================
# CONFIGURAÇÕES DO SERVIDOR
# ======================
# Porta do servidor
PORT=8000

# Host (use 0.0.0.0 para aceitar conexões de qualquer IP)
HOST=0.0.0.0

# CORS - Origens permitidas (separadas por vírgula)
# Em produção, especifique apenas os domínios autorizados
CORS_ORIGINS=*

# ======================
# AMBIENTE
# ======================
# development, staging, production
ENVIRONMENT=development